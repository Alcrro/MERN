# ── Backend URL ────────────────────────────────────────────────
# Local dev: lasă gol — CRA proxy trimite /api/* către localhost:5000
# Producție: URL-ul Render/Railway (fără slash la final)
REACT_APP_API_URL=https://your-backend.onrender.com

# ── Stripe ─────────────────────────────────────────────────────
# Cheia publică (pk_) — nu e secretă, merge în frontend
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_...   # sau pk_test_... pentru dev
