# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRE=30d

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# URL frontend (fără slash la final) — folosit la return_url Stripe și CORS
CLIENT_URL=https://your-frontend.vercel.app

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # sau sk_test_... pentru dev
STRIPE_PUBLISHABLE_KEY=pk_live_...     # trimis la frontend via /api/stripe/config
STRIPE_WEBHOOK_SECRET=whsec_...        # din Stripe Dashboard → Webhooks

# ── Cloudinary (upload avatar și imagini produse) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
NEWSLETTER_FROM=newsletter@yourdomain.com

# ── OpenAI (opțional — funcționalități AI) ────────────────────
OPENAI_API_KEY=sk-...
